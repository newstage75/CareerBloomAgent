rules_version = '2';

// Defense-in-depth: アプリケーション層では常に認証uidスコープのアクセスのみ許可されているが、
// もし誤って Firebase Client SDK 経由で直接アクセスされた場合に他人のデータが見えないよう
// 全リクエストを拒否する。バックエンドは Admin SDK でこれをバイパスする。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}